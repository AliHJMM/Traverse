// Runs on the Jenkins controller itself (no separate agents configured --
// Maven/Node/Firefox/Docker CLI are all installed directly in the custom
// jenkins/Dockerfile image, see that file for why).
//
// The backend services build in a genuine sequential loop, not a `matrix`/
// `parallel` block: Declarative Pipeline's parallel branches run as
// concurrent threads inside the ONE node this pipeline already allocated
// (agent any, above) -- they are not gated by Jenkins executor count at
// all, so numExecutors has no effect on them. With 6 full JVMs (Maven +
// Spring Boot test contexts) running at once, that briefly pushed this
// container to ~3.3GB / 44% of Docker Desktop's entire 7.4GB VM allocation
// (which is shared with the other 13 already-running containers) and
// nearly OOM-killed a build. One service at a time avoids that entirely.
def BACKEND_SERVICES = ['discovery-server', 'gateway', 'auth-service', 'user-service', 'travel-service', 'payment-service']

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
    }

    stages {
        stage('Backend: build & test') {
            steps {
                script {
                    for (svc in BACKEND_SERVICES) {
                        dir("Backend/${svc}") {
                            sh 'mvn -B clean verify'
                        }
                        junit testResults: "Backend/${svc}/target/surefire-reports/*.xml", allowEmptyResults: true
                    }
                }
            }
        }

        stage('Frontend: build & test') {
            steps {
                dir('Frontend') {
                    sh 'npm ci'
                    sh 'npx ng test --watch=false --browsers=FirefoxHeadless --code-coverage'
                    sh 'npx ng build'
                }
            }
        }

        stage('SonarQube: analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    script {
                        for (svc in BACKEND_SERVICES) {
                            dir("Backend/${svc}") {
                                sh "mvn -B sonar:sonar -Dsonar.projectKey=traverse-${svc} -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml"
                            }
                        }
                    }
                    dir('Frontend') {
                        sh '''
                            sonar-scanner \
                              -Dsonar.projectKey=traverse-frontend \
                              -Dsonar.sources=src \
                              -Dsonar.tests=src \
                              -Dsonar.test.inclusions=**/*.spec.ts \
                              -Dsonar.exclusions=**/*.spec.ts \
                              -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        '''
                    }
                }
            }
        }

        stage('Quality gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // Deploys against the REAL project directory (bind-mounted into
        // this container, see docker-compose.yml's jenkins service), not
        // Jenkins's own git-cloned workspace -- that clone never has .env
        // (gitignored, so `git checkout` never produces it), which would
        // leave every ${VAR} in docker-compose.yml resolving to empty.
        // /host-project is the actual host path already running the full
        // stack, reached through the same mounted docker.sock.
        //
        // -p traverse pins the compose project name explicitly. Without it,
        // compose infers the name from the current directory basename --
        // "traverse" on the host (C:\Users\AliHa\Traverse) but "host-project"
        // in here (the bind-mount point), a DIFFERENT project. That mismatch
        // still creates the fixed container_name: containers, but under a
        // new project's network/volumes, and collides with the already-
        // running same-named containers from the original "traverse"
        // project -- "Conflict. The container name ... is already in use".
        //
        // Delegates to the Ansible deploy playbook (Plan.md Phase 9)
        // instead of a raw `docker compose` shell step. The playbook's own
        // service list (ansible/playbooks/group_vars/all.yml) is the same
        // deliberately-scoped set used here before -- NOT
        // jenkins/sonarqube/sonarqube-db, which live in this same compose
        // file as CI infrastructure. A bare `docker compose up -d --build`
        // recreates every service including jenkins itself, and compose
        // stops the old container before starting the replacement -- which
        // kills the very Jenkins process running this pipeline mid-command,
        // leaving the recreation half-finished (confirmed live: build #13
        // took down traverse-jenkins and traverse-discovery-server and
        // never came back to finish starting their replacements).
        //
        // health_check_*_url overrides point at the containers' own service
        // names on traverse-net, not localhost -- "localhost" inside this
        // Jenkins container means the Jenkins container itself, not the
        // gateway/frontend containers the default (WSL/host-run) URLs
        // assume.
        //
        // ANSIBLE_CONFIG is set explicitly rather than relying on Ansible's
        // cwd-based auto-discovery of ansible.cfg -- see ansible/README.md
        // for why (a real WSL/DrvFs quirk hit during Phase 9 verification).
        //
        // Deliberately NOT wrapped in a `dir('/host-project/ansible')` step
        // -- Jenkins' `sh` step needs to create a sibling `<dir>@tmp`
        // control directory next to wherever `dir()` points, to track the
        // running shell process. `/host-project` is a read-only bind mount
        // (see docker-compose.yml's jenkins service); `dir('/host-project')`
        // is fine because its sibling `/host-project@tmp` falls outside the
        // mount, but `dir('/host-project/ansible')` pushes the control dir
        // to `/host-project/ansible@tmp`, still inside the read-only mount
        // -- `FileSystemException: Read-only file system` (confirmed live,
        // main build #16). `cd`-ing inside the shell script instead avoids
        // Jenkins' own FilePath/control-dir logic entirely.
        stage('Deploy (main only)') {
            when {
                branch 'main'
            }
            steps {
                sh '''
                    cd /host-project/ansible
                    ANSIBLE_CONFIG=$(pwd)/ansible.cfg ansible-playbook playbooks/deploy.yml \
                      -e health_check_gateway_url=http://gateway:8080/actuator/health \
                      -e health_check_frontend_url=https://frontend:443/ \
                      -e vault_addr=http://vault:8200
                '''
            }
        }
    }
}
