# Copy this file to .env and fill in real local-dev values.
# .env is gitignored and must never be committed.

# PostgreSQL
POSTGRES_USER=traverse_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=traverse
POSTGRES_PORT=5432

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# JWT / Auth cookie (shared secret between gateway and auth-service)
JWT_SECRET=change_me_to_a_random_32_byte_plus_string
JWT_EXPIRATION_MINUTES=60
COOKIE_NAME=access_token
# false for local http dev; must be true once served over HTTPS
COOKIE_SECURE=false

# Stripe (free test-mode key, no card required: dashboard.stripe.com ->
# Developers -> API keys -> "Secret key", starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_not_configured

# PayPal (free sandbox app, no card required: developer.paypal.com ->
# Apps & Credentials -> Sandbox tab -> create an app)
PAYPAL_BASE_URI=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=not_configured
PAYPAL_CLIENT_SECRET=not_configured
