# Copy this file to .env and fill in real local-dev values.
# .env is gitignored and must never be committed.

# PostgreSQL
POSTGRES_USER=traverse_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=traverse
POSTGRES_PORT=5432

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# JWT / Auth cookie (shared secret between gateway and auth-service)
JWT_SECRET=change_me_to_a_random_32_byte_plus_string
JWT_EXPIRATION_MINUTES=60
COOKIE_NAME=access_token
# true now that the frontend serves over real HTTPS (self-signed, see
# certs/README.md) -- a Secure cookie is never sent over plain HTTP, so
# this must stay true, not the old "false for local http dev" default.
COOKIE_SECURE=true

# Stripe (free test-mode key, no card required: dashboard.stripe.com ->
# Developers -> API keys -> "Secret key", starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_not_configured
# Same dashboard page, "Publishable key" (pk_test_...) -- safe to expose
# client-side by design, used by the Angular frontend's Stripe Elements.
STRIPE_PUBLISHABLE_KEY=pk_test_not_configured

# PayPal (free sandbox app, no card required: developer.paypal.com ->
# Apps & Credentials -> Sandbox tab -> create an app)
PAYPAL_BASE_URI=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=not_configured
PAYPAL_CLIENT_SECRET=not_configured

# SonarQube's own Postgres database (internal only, not the app's DB)
SONARQUBE_DB_USER=sonar
SONARQUBE_DB_PASSWORD=change_me
# Bootstrapped once from the default admin/admin via the API (see Plan.md
# Phase 8) -- for the SonarQube UI at :9000 only, not read by any service.
SONARQUBE_ADMIN_PASSWORD=change_me

# GitHub Personal Access Token used by Jenkins to check out the repo and
# report build status back onto commits/PRs (classic PAT with "repo" scope:
# github.com -> Settings -> Developer settings -> Personal access tokens)
GITHUB_TOKEN=not_configured

# Generated once SonarQube is up and its admin password has been changed
# from the default (see Plan.md Phase 8 for the one-time bootstrap steps)
SONARQUBE_TOKEN=not_configured

# Jenkins admin login (provisioned declaratively via jenkins/casc.yaml)
JENKINS_ADMIN_PASSWORD=change_me

# Grafana admin login (Loki datasource provisioned declaratively, see
# logging/grafana-provisioning-datasources) -- UI at http://localhost:3000
GRAFANA_ADMIN_PASSWORD=change_me

# Vault dev-mode root token (fixed, not randomly generated per-start, so
# Ansible can authenticate to it -- see ansible/roles/vault_secrets).
# UI at http://localhost:8200. Dev mode only -- not how Vault would be run
# in production (see Plan.md Phase 11 for why that's an honest, documented
# trade-off here).
VAULT_ROOT_TOKEN=change_me
